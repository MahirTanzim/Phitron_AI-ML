print(arr.size)





# np.random.uniform(startpoint, endpoint, shape)
import numpy as np
# arr = np.random.unifor(1, 10, (3,4))   # create a 1d array of random integer number (must define the range (1-10))
arr = np.random.uniform(1, 100, (10,10))   # create a 2d array of random integer number (must define the range (1-10))
