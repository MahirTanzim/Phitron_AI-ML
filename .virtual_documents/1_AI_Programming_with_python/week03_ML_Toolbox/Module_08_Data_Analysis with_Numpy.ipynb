arr1 = np.array([1,2,3,4,5])
arr_mod = arr1[1:4]
print(arr1)
arr_mod[1]=7
print(arr1)    # change in a sliced array will efect the main array because it a view not copy
print(arr_mod)



#copy sliced array
arr1 = np.array([1,2,3,4,5])
arr_mod = arr1[1:4].copy()
print(arr1)
arr_mod[1]=7
print(arr1)    # change in a sliced array will efect the main array because it a view not copy
print(arr_mod)





