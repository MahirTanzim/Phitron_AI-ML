#dictionary
dic = {"a": 10, "b" : 20, "c" : 30}
k = (dic.keys())
v = dic.values()
items = dic.items()
print(k)
print(v)
print(items)

#for keys
arr = np.array(list(k))
print(arr)
print(type(arr))
print(arr.dtype)
print(arr.shape)
print(arr.ndim)

# for values
arr = np.array(list(v), dtype = np.int32)
print(arr)
print(type(arr))
print(arr.dtype)
print(arr.shape)
print(arr.ndim)
# for items
arr = np.array(list(items))
print(arr)
print(type(arr))
print(arr.dtype)
print(arr.shape)
print(arr.ndim)








