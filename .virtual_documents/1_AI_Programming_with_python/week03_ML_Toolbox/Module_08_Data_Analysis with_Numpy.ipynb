print(arr.dtype)
print(arr.shape)
print(arr.ndim)
print(arr.size)





# np.arange(first, end, step) -> smilar to range function
# np.arange(first, end, step).reshape(x,y) -> to turn into matrix
arr = np.arange(1, 101, 1)
arr = arr.reshape(5,20)
print(arr)
print(type(arr))
print(arr.dtype)
print(arr.shape)
print(arr.ndim)
print(arr.size)


# np.linspace(start, end(included), koyta)
arr = np.linspace(1, 1000, 11)   # pic the number of point in the range
print(arr)
print(type(arr))
print(arr.dtype)
print(arr.shape)
print(arr.ndim)
print(arr.size)


# np.logspace(start, end(included), number of points, base(default 10))
arr = np.logspace(0, 4, 6, base=3)   # here start and end point is base power the point lione base^0 and base^4
print(arr)
print(type(arr))
print(arr.dtype)
print(arr.shape)
print(arr.ndim)
print(arr.size)





#indexing
